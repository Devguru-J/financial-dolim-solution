{
  "name": "mg-lease-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --env-file=.dev.vars src/local-dev.ts",
    "dev:all": "bun scripts/dev.ts",
    "start": "bun scripts/dev.ts",
    "dev:pages": "wrangler pages dev . --ip 127.0.0.1 --port 8788 --compatibility-date=2026-03-17",
    "dev:client": "cd client && bun run dev",
    "test": "bun test",
    "build": "cd client && bun install && bun run build",
    "postinstall": "cd client && bun install && bun run build",
    "typecheck": "tsc --noEmit",
    "check": "bun run typecheck",
    "extract:mg:operating-lease-fixture": "bun scripts/extract-mg-operating-lease-fixture.ts",
    "db:generate": "bun --env-file=.dev.vars ./node_modules/drizzle-kit/bin.cjs generate",
    "db:migrate": "bun --env-file=.dev.vars ./node_modules/drizzle-kit/bin.cjs migrate",
    "db:push": "bun --env-file=.dev.vars scripts/db-push.ts"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.7.2",
    "drizzle-orm": "^0.44.2",
    "hono": "^4.9.8",
    "postgres": "^3.4.7",
    "xlsx": "^0.18.5",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260312.0",
    "@types/node": "^24.5.2",
    "drizzle-kit": "^0.31.4",
    "typescript": "^5.9.2",
    "wrangler": "^4.38.0"
  }
}
